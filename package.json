{
  "name": "temp-inbox-manager",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Tauri + SvelteKit desktop scaffold for Temp Inbox Manager",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js dev",
    "build": "node ./node_modules/vite/bin/vite.js build",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "check": "node ./node_modules/@sveltejs/kit/svelte-kit.js sync; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; node ./node_modules/svelte-check/bin/svelte-check --tsconfig ./tsconfig.json",
    "lint": "node ./node_modules/eslint/bin/eslint.js src vite.config.ts svelte.config.js eslint.config.js",
    "test": "node ./node_modules/vitest/vitest.mjs run",
    "test:watch": "node ./node_modules/vitest/vitest.mjs",
    "export:local": "& \"./scripts/export-local.ps1\"",
    "tauri": "node ./node_modules/@tauri-apps/cli/tauri.js",
    "tauri:dev": "node ./node_modules/@tauri-apps/cli/tauri.js dev",
    "tauri:build": "node ./node_modules/@tauri-apps/cli/tauri.js build"
  },
  "dependencies": {
    "@tauri-apps/api": "2.10.1",
    "svelte": "4.2.19"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "3.0.1",
    "@sveltejs/kit": "2.5.7",
    "@tauri-apps/cli": "2.10.1",
    "@types/node": "^22.10.1",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "eslint": "^9.14.0",
    "eslint-plugin-svelte": "^2.46.0",
    "globals": "^15.12.0",
    "svelte-check": "^3.8.6",
    "svelte-eslint-parser": "^0.42.0",
    "tslib": "^2.8.1",
    "typescript": "^5.6.3",
    "vite": "5.4.10",
    "vitest": "1.6.0"
  }
}
